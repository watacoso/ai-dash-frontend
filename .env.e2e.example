# Copy this file to .env.e2e and fill in your credentials.
# .env.e2e is gitignored — never commit real credentials.
#
# These values are used only by the "Explore — live chat" E2E tests.
# If this file is absent or E2E_SF_ACCOUNT is empty, those tests are skipped.

# Snowflake
E2E_SF_ACCOUNT=your-account-identifier
E2E_SF_USERNAME=your-service-account-username
# Store the private key on a single line with literal \n between lines:
# -----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----
E2E_SF_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
E2E_SF_WAREHOUSE=your-warehouse
E2E_SF_DATABASE=your-database
# Leave blank if the key has no passphrase:
E2E_SF_PASSPHRASE=

# Claude (Anthropic)
E2E_CL_API_KEY=sk-ant-...
E2E_CL_MODEL=claude-sonnet-4-6
